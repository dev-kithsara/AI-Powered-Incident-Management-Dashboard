# ─── APPLICATION ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000

# ─── DATABASE ─────────────────────────────────────────────────────────
POSTGRES_DB=incident_management
POSTGRES_USER=ims_user
POSTGRES_PASSWORD=ims_password_change_me
DATABASE_URL=postgresql://ims_user:ims_password_change_me@localhost:5432/incident_management

# ─── AUTH ─────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# ─── AI SERVICE ───────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001
AI_API_KEY=internal_ai_key_change_me
SCHEDULER_INTERVAL_MINUTES=5
MIN_SIMILARITY_THRESHOLD=0.4

# ─── REDIS ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── FRONTEND ─────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_AI_API_URL=http://localhost:8001
