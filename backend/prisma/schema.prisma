generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(150)
  password  String   @db.VarChar(255)
  role      String   @default("staff")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  reportedIncidents Incident[]             @relation("ReportedBy")
  assignedActions   IncidentAction[]       @relation("AssignedTo")
  investigations    IncidentInvestigation[]
  controlsOwned     IncidentControl[]
  reviews           IncidentReview[]
  closures          IncidentClosure[]
  auditLogs         AuditLog[]

  @@map("users")
}

model Incident {
  id                 Int       @id @default(autoincrement())
  title              String    @db.VarChar(255)
  description        String
  severity           String
  category           String?   @db.VarChar(100)
  location           String?   @db.VarChar(200)
  department         String?   @db.VarChar(100)
  reportedBy         Int?      @map("reported_by")
  status             String    @default("OPEN")
  aiProcessed        Boolean   @default(false) @map("ai_processed")
  predictedRiskScore Float?    @map("predicted_risk_score")
  clusterId          Int?      @map("cluster_id")
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  reporter      User?                  @relation("ReportedBy", fields: [reportedBy], references: [id])
  actions       IncidentAction[]
  investigation IncidentInvestigation?
  rootCause     IncidentRootCause?
  controls      IncidentControl[]
  review        IncidentReview?
  closure       IncidentClosure?
  embedding     AiEmbedding?

  @@map("incidents")
}

model IncidentAction {
  id          Int       @id @default(autoincrement())
  incidentId  Int       @map("incident_id")
  actionTaken String    @map("action_taken")
  assignedTo  Int?      @map("assigned_to")
  priority    String    @default("MEDIUM")
  dueDate     DateTime? @map("due_date") @db.Date
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  assignee User?    @relation("AssignedTo", fields: [assignedTo], references: [id])

  @@map("incident_actions")
}

model IncidentInvestigation {
  id                Int       @id @default(autoincrement())
  incidentId        Int       @unique @map("incident_id")
  findings          String?
  evidence          String?
  evidenceFiles     String[]  @map("evidence_files")
  investigatedBy    Int?      @map("investigated_by")
  investigationDate DateTime? @map("investigation_date") @db.Date
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  incident     Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  investigator User?    @relation(fields: [investigatedBy], references: [id])

  @@map("incident_investigations")
}

model IncidentRootCause {
  id                  Int      @id @default(autoincrement())
  incidentId          Int      @unique @map("incident_id")
  rootCauseCategory   String   @map("root_cause_category")
  description         String
  contributingFactors String?  @map("contributing_factors")
  causalChain         String?  @map("causal_chain")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@map("incident_root_causes")
}

model IncidentControl {
  id                 Int       @id @default(autoincrement())
  incidentId         Int       @map("incident_id")
  controlType        String    @map("control_type")
  description        String
  owner              Int?
  implementationDate DateTime? @map("implementation_date") @db.Date
  status             String    @default("PLANNED")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  incident     Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  controlOwner User?    @relation(fields: [owner], references: [id])

  @@map("incident_controls")
}

model IncidentReview {
  id                  Int       @id @default(autoincrement())
  incidentId          Int       @unique @map("incident_id")
  reviewerId          Int?      @map("reviewer_id")
  reviewNotes         String?   @map("review_notes")
  effectivenessRating Int?      @map("effectiveness_rating")
  reviewDate          DateTime? @map("review_date") @db.Date
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  reviewer User?    @relation(fields: [reviewerId], references: [id])

  @@map("incident_reviews")
}

model IncidentClosure {
  id             Int      @id @default(autoincrement())
  incidentId     Int      @unique @map("incident_id")
  closureSummary String   @map("closure_summary")
  lessonsLearned String?  @map("lessons_learned")
  closedBy       Int?     @map("closed_by")
  closureDate    DateTime @map("closure_date") @db.Date
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  closer   User?    @relation(fields: [closedBy], references: [id])

  @@map("incident_closures")
}

model AiEmbedding {
  id         Int                              @id @default(autoincrement())
  incidentId Int                              @unique @map("incident_id")
  embedding  Unsupported("vector(384)")?
  umapX      Float?                           @map("umap_x")
  umapY      Float?                           @map("umap_y")
  textHash   String?                          @map("text_hash") @db.VarChar(64)
  createdAt  DateTime                         @default(now()) @map("created_at")
  updatedAt  DateTime                         @updatedAt @map("updated_at")

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@map("ai_embeddings")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  action     String   @db.VarChar(50)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   Int?     @map("entity_id")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model ModelMetrics {
  id              Int      @id @default(autoincrement())
  modelType       String   @map("model_type") @db.VarChar(50)
  accuracy        Float?
  precisionScore  Float?   @map("precision_score")
  recallScore     Float?   @map("recall_score")
  f1Score         Float?   @map("f1_score")
  trainingSamples Int?     @map("training_samples")
  optimalK        Int?     @map("optimal_k")
  silhouetteScore Float?   @map("silhouette_score")
  trainedAt       DateTime @default(now()) @map("trained_at")

  @@map("model_metrics")
}
